# TailorX Backend — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ─── PostgreSQL ───────────────────────────────
# Option A: Full connection string (recommended for Railway / Supabase / Render)
DATABASE_URL=postgresql://username:password@host:5432/tailorx_db

# Option B: Individual fields (if DATABASE_URL is not available)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=tailorx_db
# DB_USER=postgres
# DB_PASSWORD=yourpassword

# ─── JWT Secret ───────────────────────────────
# Generate a strong random string (at least 64 chars)
# Run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_YOUR_STRONG_SECRET_KEY_AT_LEAST_64_CHARS

# ─── Server ───────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── CORS ─────────────────────────────────────
# Your frontend domain (set after deploying frontend)
FRONTEND_URL=https://your-frontend-domain.com
